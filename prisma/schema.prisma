generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum VehicleType {
  CAR
  MOTORCYCLE
  BICYCLE
  BUS
}

enum VehicleStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
}

enum RentalStatus {
  PENDING
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum PaymentMethod {
  TRANSFER
  VA
  EWALLET
  CASH
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(USER)
  rentals   Rental[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  avatarUrl String?
}

model Vehicle {
  id          String        @id @default(uuid())
  name        String
  type        VehicleType
  brand       String
  model       String
  year        Int
  plateNumber String        @unique
  pricePerDay Decimal       @db.Decimal(12, 2)
  status      VehicleStatus @default(AVAILABLE)
  location    String?       // ← tambah ini
  imageUrl    String?
  description String?       @db.Text
  rentals     Rental[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Rental {
  id         String       @id @default(uuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  vehicleId  String
  vehicle    Vehicle      @relation(fields: [vehicleId], references: [id])
  startDate  DateTime
  endDate    DateTime
  totalPrice Decimal      @db.Decimal(12, 2)
  status     RentalStatus @default(PENDING)
  payment    Payment?
  invoice    Invoice?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Payment {
  id        String        @id @default(uuid())
  rentalId  String        @unique
  rental    Rental        @relation(fields: [rentalId], references: [id])
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(TRANSFER)
  status    PaymentStatus @default(PENDING)
  reference String        @unique
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Invoice {
  id            String   @id @default(uuid())
  rentalId      String   @unique
  rental        Rental   @relation(fields: [rentalId], references: [id])
  invoiceNumber String   @unique
  issuedAt      DateTime @default(now())
  amount        Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}